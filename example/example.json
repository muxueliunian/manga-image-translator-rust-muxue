{
  "$schema": "https://raw.githubusercontent.com/frederik-uni/manga-image-translator-rust/refs/heads/master/example/schema.json",

  "upscaler": { "upscaler": null, "patch_size": null, "padding": 0 },
  "detector": {
    "detector": "DBNet",
    "preprocessor": {
      "invert": false,
      "gamma_correct": false,
      "rotate": false,
      "auto_rotate": false
    },
    "options": {
      "detect_size": 2048,
      "unclip_ratio": 2.3,
      "text_threshold": 0.5,
      "box_threshold": 0.7
    }
  },
  "ocr": {
    "ocr": "Ocr48px",
    "use_mocr_merge": false,
    "min_text_length": 1,
    "filter_text": [],
    "prob": 0.2
  },
  "mask_refinement": {
    "ignore_bubble": 0,
    "dilation_offset": 20.0,
    "kernel_size": 3,
    "furigana": false,
    "method": "FitText"
  },
  "inpainter": {
    "inpainter": "LamaAot",
    "inpainting_size": 2048,
    "inpaint_color": [255, 255, 255],
    "mask": "RefinedMask"
  },
  "translator": {
    "target": { "translator": "NLLBSmallDistilled", "target": "en" },
    "filter_lang": ["en"],
    "pre_dict": null
  },
  "render": { "renderer": "Raw" }
}
